{
    "compilerOptions": {
        "baseUrl": ".",
        "module": "ESNext",
        "target": "ES2018",
        "lib": ["DOM", "ES2018"],
        "allowJs": false,
        "strict": true,
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["**/*.ts", "**/*.d.ts"],
    "exclude": ["node_modules"]
}
